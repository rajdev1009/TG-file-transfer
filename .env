# ============================================================
#  TG BULK TRANSFER BOT — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit your real .env to version control.
# ============================================================

# --- Cloud Deployment ---
PORT=8080

# --- Telegram API Credentials ---
API_ID=12345678
API_HASH=your_api_hash_here_abcdef1234567890

# --- Telegram Authentication (choose ONE) ---
SESSION_STRING=BQC_your_very_long_session_string_here
# BOT_TOKEN=1234567890:ABCDefGhIjKlMnOpQrStUvWxYz

# --- Channel IDs ---
SOURCE_CHAT_ID=-1001234567890
DEST_CHAT_ID=-1009876543210

# --- Neon DB / PostgreSQL ---
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Optional Tuning ---
COPY_DELAY=2
SCRAPE_BATCH_SIZE=200
